<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Dabber" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>
        <item name="colorSecondary">@color/brand_primary</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <item name="colorSecondaryContainer">@color/brand_primary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_primary_container</item>
        <item name="colorTertiary">@color/brand_primary</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/app_background</item>
        <item name="colorSurface">@color/app_surface</item>
        <item name="colorSurfaceContainer">@color/app_surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/muted</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline</item>
        <item name="colorError">@color/brand_accent</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>
</resources>
