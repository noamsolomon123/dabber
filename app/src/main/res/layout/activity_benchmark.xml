<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="@color/app_background"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutDirection="rtl"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- ============================ HERO / HEADER ============================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="24dp"
            android:paddingTop="22dp"
            android:paddingBottom="22dp">

            <ImageView
                android:id="@+id/backBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/bench_back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/hero_on" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bench_title"
                    android:textColor="@color/hero_on"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/bench_subtitle"
                    android:textColor="@color/hero_on_muted"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_hero_chip"
                android:contentDescription="@null"
                android:padding="13dp"
                android:src="@drawable/ic_speed"
                app:tint="@color/hero_on" />
        </LinearLayout>

        <!-- ====================== VARIANT PICKER CARD ======================= -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/app_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bench_pick_title"
                    android:textColor="@color/on_surface"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/bench_pick_desc"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/variantToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQ4"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|end"
                        android:textAlignment="viewEnd"
                        app:cornerRadius="14dp"
                        tools:text="q4_0 — קטן ומהיר (453MB)" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQ5"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical|end"
                        android:textAlignment="viewEnd"
                        app:cornerRadius="14dp"
                        tools:text="q5_0 — בינוני (548MB)" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnQ8"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical|end"
                        android:textAlignment="viewEnd"
                        app:cornerRadius="14dp"
                        tools:text="q8_0 — הכי מדויק (834MB)" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_scratch"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_download"
                        app:tint="@color/brand_working" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="@string/bench_warn"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/benchRunBtn"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="18dp"
                    android:text="@string/bench_run"
                    android:textSize="16sp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_speed"
                    app:iconGravity="textStart" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/benchProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorColor="@color/brand_primary"
                    app:trackColor="@color/surface_variant"
                    app:trackCornerRadius="6dp"
                    app:trackThickness="6dp"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/benchStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="@string/bench_idle"
                    android:textColor="@color/muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========================= RESULTS CARD ========================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/benchResultsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/app_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bench_results_title"
                    android:textColor="@color/on_surface"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/benchDevice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    tools:text="מכשיר: Pixel 7" />

                <!-- Comparison-table header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_scratch"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.8"
                        android:text="@string/bench_col_model"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.7"
                        android:gravity="center"
                        android:text="@string/bench_col_ms"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.6"
                        android:gravity="center"
                        android:text="@string/bench_col_rtf"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.3"
                        android:gravity="center"
                        android:text="@string/bench_col_wer"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- One summary row per completed run is appended here, in code. -->
                <LinearLayout
                    android:id="@+id/benchTable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/outline" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bench_details_title"
                    android:textColor="@color/muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:textAllCaps="true" />

                <!-- One expandable per-clip detail block per run is appended here, in code. -->
                <LinearLayout
                    android:id="@+id/benchDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
